                ],
                [
                    462.0,
                    1209.0
                ],
                [
                    462.0,
                    1237.0
                ],
                [
                    94.0,
                    1237.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "• Prune lower tree limbs to at least 6 feet up to 15 feet (or lower 1/3 of branches on smaller trees).",
            "block_bbox": [
                92,
                1239,
                1144,
                1268
            ],
            "block_id": 15,
            "block_order": 14,
            "group_id": 15,
