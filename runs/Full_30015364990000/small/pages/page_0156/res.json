                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "The State Forester may allow exemptions from the above upon receiving a written request and granting subsequent approval in writing. You may apply for an exemption on the Forestry Division website at nmforestry.com.",
            "block_bbox": [
                86,
                962,
                934,
                1043
            ],
            "block_id": 8,
            "block_order": 9,
            "group_id": 8,
            "block_polygon_points": [
