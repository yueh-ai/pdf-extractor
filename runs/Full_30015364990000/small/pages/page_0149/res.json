    "parsing_res_list": [
        {
            "block_label": "paragraph_title",
            "block_content": "NEW MEXICO OIL CONSERVATION DIVISION\nDISTRICT 2 OFFICE\n811 SOUTH FIRST STREET\nARTESIA, NM 88210\n(575)748-1283\nOF APPROVAL for FLARING or VENTING GAS",
            "block_bbox": [
                294,
                135,
                940,
                300
            ],
            "block_id": 0,
            "block_order": 1,
            "group_id": 0,
            "block_polygon_points": [
                [
