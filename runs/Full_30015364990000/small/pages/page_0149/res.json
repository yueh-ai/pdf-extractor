                ],
                [
                    294.0,
                    300.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "1. Venting gas is absolutely not allowed.",
            "block_bbox": [
                241,
                329,
                626,
                356
            ],
            "block_id": 1,
            "block_order": 2,
            "group_id": 1,
            "block_polygon_points": [
                [
                    241.0,
                    329.0
                ],
                [
                    626.0,
                    329.0
                ],
                [
                    626.0,
                    356.0
                ],
                [
                    241.0,
                    356.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "2. Prior to flaring gas, C-129 must be filed & approved. Blanket approval cannot be given for this operation.",
            "block_bbox": [
                239,
                360,
                1055,
                412
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
            "block_polygon_points": [
                [
                    239.0,
                    360.0
                ],
                [
                    1055.0,
                    360.0
                ],
                [
                    1055.0,
                    412.0
                ],
                [
                    239.0,
                    412.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "3. Flared volumes of gas are to be metered & reported.",
            "block_bbox": [
                240,
                416,
                745,
                443
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
                [
                    240.0,
                    416.0
                ],
                [
                    745.0,
                    416.0
                ],
                [
                    745.0,
                    443.0
                ],
                [
                    240.0,
                    443.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "4. Flares WILL be manned at all times. Brush should be cut down to 1 or 2 inches around flare stack at least a radial distance of 2 times the height of the flare stack.",
            "block_bbox": [
                240,
                448,
                1054,
                499
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
                [
                    240.0,
