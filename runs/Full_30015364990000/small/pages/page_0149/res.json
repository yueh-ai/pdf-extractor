                ],
                [
                    1054.0,
                    448.0
                ],
                [
                    1054.0,
                    499.0
                ],
                [
                    240.0,
                    499.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5. Flares WILL NOT be left unattended.",
            "block_bbox": [
                241,
                504,
                618,
                530
            ],
            "block_id": 5,
            "block_order": 6,
            "group_id": 5,
            "block_polygon_points": [
