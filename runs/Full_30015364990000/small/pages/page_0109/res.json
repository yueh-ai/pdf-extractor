                    240.0,
                    485.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "4. Flares WILL be manned at all times. Brush should be cut down to 1 or 2 inches around flare stack at least a radial distance of 2 times the height of the flare stack.",
            "block_bbox": [
                238,
                489,
                1055,
                541
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
