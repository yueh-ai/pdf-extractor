                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "6. No flaring operations to be conducted during red-flag days.\nhttp://www.gacc.nifc.gov/swcc (go to \"Predictive Services\" on SWCC website) to check for red flag warnings.",
            "block_bbox": [
                236,
