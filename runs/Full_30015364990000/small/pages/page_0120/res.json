                [
                    276.0,
                    314.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "1. Venting gas is absolutely not allowed.",
            "block_bbox": [
                241,
                339,
                625,
                368
            ],
            "block_id": 2,
            "block_order": 2,
            "group_id": 2,
            "block_polygon_points": [
                [
                    241.0,
