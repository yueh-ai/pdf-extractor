                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "1. Venting gas is absolutely not allowed.",
            "block_bbox": [
                247,
                368,
                632,
                397
            ],
            "block_id": 1,
            "block_order": 2,
            "group_id": 1,
            "block_polygon_points": [
                [
                    247.0,
