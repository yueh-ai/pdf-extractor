                [
                    245.0,
                    452.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "3. Flared volumes of gas are to be metered & reported.",
            "block_bbox": [
                244,
                456,
                746,
                484
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
                [
                    244.0,
