        {
            "block_label": "paragraph_title",
            "block_content": "NOTICE TO OPERATORS",
            "block_bbox": [
                453,
                518,
                735,
                546
            ],
            "block_id": 6,
            "block_order": 6,
            "group_id": 6,
            "block_polygon_points": [
