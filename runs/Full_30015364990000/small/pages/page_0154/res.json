                    281.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "1. Venting gas is absolutely not allowed.",
            "block_bbox": [
                220,
                303,
                607,
                334
            ],
            "block_id": 1,
            "block_order": 2,
            "group_id": 1,
            "block_polygon_points": [
                [
                    220.0,
                    303.0
