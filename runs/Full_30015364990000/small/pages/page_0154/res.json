                [
                    220.0,
                    334.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "2. Prior to flaring gas, C-129 must be filed & approved. Blanket approval cannot be given for this operation.",
            "block_bbox": [
                218,
                335,
                1034,
                392
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
            "block_polygon_points": [
                [
                    218.0,
