                [
                    219.0,
                    479.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5. Flares WILL NOT be left unattended.",
            "block_bbox": [
                220,
                479,
                599,
                508
            ],
            "block_id": 5,
            "block_order": 6,
            "group_id": 5,
