                ],
                [
                    218.0,
                    392.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "3. Flared volumes of gas are to be metered & reported.",
            "block_bbox": [
                219,
                391,
                725,
                422
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
                [
                    219.0,
                    391.0
                ],
                [
                    725.0,
                    391.0
