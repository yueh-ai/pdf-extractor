                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5. Flares WILL NOT be left unattended.",
            "block_bbox": [
                241,
                512,
                618,
                538
            ],
            "block_id": 5,
            "block_order": 6,
            "group_id": 5,
