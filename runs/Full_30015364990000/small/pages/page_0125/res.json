                [
                    237.0,
                    428.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "3. Flared volumes of gas are to be metered & reported.",
            "block_bbox": [
                238,
                432,
                739,
                460
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
                [
                    238.0,
                    432.0
                ],
                [
                    739.0,
                    432.0
                ],
                [
                    739.0,
                    460.0
                ],
                [
                    238.0,
                    460.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "4. Flares WILL be manned at all times. Brush should be cut down to 1 or 2 inches around flare stack at least a radial distance of 2 times the height of the flare stack.",
            "block_bbox": [
                237,
                464,
                1046,
                516
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
