                [
                    237.0,
                    516.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5. Flares WILL NOT be left unattended.",
            "block_bbox": [
                239,
                519,
                613,
                546
            ],
            "block_id": 5,
            "block_order": 6,
            "group_id": 5,
