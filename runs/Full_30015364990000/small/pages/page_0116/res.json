                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "3. Flared volumes of gas are to be metered & reported.",
            "block_bbox": [
                236,
                442,
                737,
                469
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
                [
