            ]
        },
        {
            "block_label": "text",
            "block_content": "5. Flares WILL NOT be left unattended.",
            "block_bbox": [
                237,
                529,
                611,
                555
            ],
            "block_id": 6,
            "block_order": 7,
            "group_id": 6,
