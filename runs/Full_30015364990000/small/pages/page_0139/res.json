        },
        {
            "block_label": "text",
            "block_content": "7. Follow safe practices for flaring guidelines.",
            "block_bbox": [
                242,
                630,
                675,
                659
            ],
            "block_id": 7,
            "block_order": 8,
            "group_id": 7,
