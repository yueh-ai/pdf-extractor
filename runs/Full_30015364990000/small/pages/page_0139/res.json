                ],
                [
                    273.0,
                    316.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "1. Venting gas is absolutely not allowed.",
            "block_bbox": [
                243,
                342,
                626,
                370
            ],
            "block_id": 1,
            "block_order": 2,
            "group_id": 1,
            "block_polygon_points": [
                [
                    243.0,
                    342.0
                ],
                [
                    626.0,
                    342.0
                ],
                [
                    626.0,
                    370.0
                ],
                [
                    243.0,
                    370.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "2. Prior to flaring gas, C-129 must be filed & approved. Blanket approval cannot be given for this operation.",
            "block_bbox": [
                240,
                374,
                1054,
                426
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
            "block_polygon_points": [
                [
                    239.9312286376953,
                    374.0614013671875
                ],
                [
                    1052.5572509765625,
                    367.00390625
                ],
                [
                    1053.0001220703125,
                    418.00006103515625
                ],
                [
                    240.3741455078125,
                    425.05755615234375
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "3. Flared volumes of gas are to be metered & reported.",
            "block_bbox": [
                241,
                430,
                745,
                458
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
                [
                    241.0,
                    430.0
                ],
                [
                    745.0,
                    430.0
                ],
                [
                    745.0,
                    458.0
                ],
                [
                    241.0,
                    458.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "4. Flares WILL be manned at all times. Brush should be cut down to 1 or 2 inches around flare stack at least a radial distance of 2 times the height of the flare stack.",
            "block_bbox": [
                240,
                462,
                1052,
                514
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
                [
                    240.0,
