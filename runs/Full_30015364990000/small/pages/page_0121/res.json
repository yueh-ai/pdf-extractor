        {
            "block_label": "paragraph_title",
            "block_content": "Notice to Oil and Gas Facilities and Operators Flaring Gas in New Mexico",
            "block_bbox": [
                127,
                486,
                1102,
                519
            ],
            "block_id": 8,
            "block_order": 7,
            "group_id": 8,
            "block_polygon_points": [
