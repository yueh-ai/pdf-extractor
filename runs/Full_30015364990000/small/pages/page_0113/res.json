            ]
        },
        {
            "block_label": "text",
            "block_content": "7. Follow safe practices for flaring guidelines.",
            "block_bbox": [
                243,
                694,
                671,
                722
            ],
            "block_id": 7,
            "block_order": 8,
            "group_id": 7,
