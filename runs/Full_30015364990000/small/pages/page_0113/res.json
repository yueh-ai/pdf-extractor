                    388.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "1. Venting gas is absolutely not allowed.",
            "block_bbox": [
                255,
                409,
                636,
                437
            ],
            "block_id": 1,
            "block_order": 2,
            "group_id": 1,
            "block_polygon_points": [
                [
                    255.0,
                    409.0
                ],
                [
                    636.0,
                    409.0
                ],
                [
                    636.0,
                    437.0
                ],
                [
                    255.0,
                    437.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "2. Prior to flaring gas, C-129 must be filed & approved. Blanket approval cannot be given for this operation.",
            "block_bbox": [
                252,
                441,
                1066,
                493
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
            "block_polygon_points": [
                [
                    252.0,
                    441.0
                ],
                [
                    1066.0,
