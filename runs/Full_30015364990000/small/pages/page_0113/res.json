                ],
                [
                    1061.0,
                    580.0
                ],
                [
                    249.0,
                    580.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5. Flares WILL NOT be left unattended.",
            "block_bbox": [
                248,
                584,
                621,
                609
            ],
            "block_id": 5,
            "block_order": 6,
            "group_id": 5,
            "block_polygon_points": [
