            ]
        },
        {
            "block_label": "text",
            "block_content": "12. The local fire department and county dispatch are notified at least 24 hours in advance of anticipated releases that will result in flaring. If flaring is done by an automated system then the schedule of flaring shall be provided to the local fire department and county dispatch. The area is mowed and maintained at a length not to exceed 4 inches and all other flammable products or debris shall be cleared in the area for a distance of one and one half times the height of the stack.",
            "block_bbox": [
                239,
                912,
                1072,
                1059
            ],
            "block_id": 14,
            "block_order": 15,
            "group_id": 14,
            "block_polygon_points": [
