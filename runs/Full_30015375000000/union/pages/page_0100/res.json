                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "13. At least one adult is on site with communications equipment adequate to reach county dispatch and the local fire department in the event of a fire. The individual should also be equipped with a shovel and a water backpack pump or other equipment to deliver water to suppress a fire.",
            "block_bbox": [
                243,
                1069,
                1032,
                1168
            ],
            "block_id": 15,
            "block_order": 16,
            "group_id": 15,
